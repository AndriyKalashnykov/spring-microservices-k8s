@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.11.0/C4_Container.puml

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",          $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("container",       $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateElementStyle("container_db",    $fontColor="#FFFFFF", $bgColor="#7C3AED", $borderColor="#4C1D95")
UpdateElementStyle("external_system", $fontColor="#1E293B", $bgColor="#E2E8F0", $borderColor="#94A3B8")
UpdateBoundaryStyle($bgColor="#F1F5F9", $borderColor="#94A3B8", $fontColor="#1E293B")

title Container diagram — Spring Microservices on Kubernetes

Person(client, "Client", "Browser, curl, Swagger UI")

System_Boundary(platform, "Spring Microservices Platform") {
    Container(gateway, "Gateway Service", "Spring Boot 4.0.5, Java 25, Spring Cloud Gateway Server WebMVC", "LoadBalancer via cloud-provider-kind; routes /employee/**, /department/**, /organization/**")

    Container(employee, "Employee Service", "Spring Boot 4.0.5, Java 25", "Employees CRUD")
    Container(department, "Department Service", "Spring Boot 4.0.5, Java 25", "Departments CRUD; calls Employee via @HttpExchange")
    Container(organization, "Organization Service", "Spring Boot 4.0.5, Java 25", "Organizations CRUD; calls Department + Employee via @HttpExchange")

    ContainerDb(mongo, "MongoDB 8.0", "MongoDB", "Shared datastore; per-service database")
}

System_Ext(jaeger, "Jaeger 2.x", "OTel-Collector-based tracing backend (OTLP receiver + UI on :16686)")

Rel(client, gateway, "HTTPS")
Rel(gateway, employee,     "routes /employee/**",     "HTTP")
Rel(gateway, department,   "routes /department/**",   "HTTP")
Rel(gateway, organization, "routes /organization/**", "HTTP")

Rel_D(department,   employee, "RestClient @HttpExchange", "HTTP")
Rel_D(organization, employee, "RestClient @HttpExchange", "HTTP")
Rel_D(organization, department, "RestClient @HttpExchange", "HTTP")

Rel(employee,     mongo, "reads/writes", "MongoDB wire")
Rel(department,   mongo, "reads/writes", "MongoDB wire")
Rel(organization, mongo, "reads/writes", "MongoDB wire")

Rel(gateway,      jaeger, "exports spans", "OTLP/HTTP :4318")
Rel(employee,     jaeger, "exports spans", "OTLP/HTTP :4318")
Rel(department,   jaeger, "exports spans", "OTLP/HTTP :4318")
Rel(organization, jaeger, "exports spans", "OTLP/HTTP :4318")

SHOW_LEGEND()
@enduml
